<Window x:Class="TrainTimer.Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="TrainTimer"
        Icon="Assets/TrainTimerIcon.png"
        Width="720"
        Height="520"
        MinWidth="660"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
  <Window.Resources>
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#DDF3F3F3" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#E4000000" />
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#99000000" />
    <SolidColorBrush x:Key="TextTertiaryBrush" Color="#73000000" />
    <SolidColorBrush x:Key="CardBrush" Color="#CFFFFFFF" />
    <SolidColorBrush x:Key="CardBorderBrush" Color="#18000000" />
    <SolidColorBrush x:Key="DividerBrush" Color="#16000000" />
    <SolidColorBrush x:Key="SubtleButtonBrush" Color="#12000000" />
    <SolidColorBrush x:Key="SubtleButtonHoverBrush" Color="#1F000000" />
    <SolidColorBrush x:Key="AccentBrush" Color="#FF0F6CBD" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="#FF115EA3" />
    <SolidColorBrush x:Key="AccentPressedBrush" Color="#FF0C3B5E" />
    <SolidColorBrush x:Key="StatusGreenBrush" Color="#FF0F9D58" />
    <SolidColorBrush x:Key="StatusAmberBrush" Color="#FFF29900" />
    <SolidColorBrush x:Key="StatusRedBrush" Color="#FFD13438" />

    <Style TargetType="TextBlock">
      <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>

    <Style x:Key="QuietButtonStyle" TargetType="Button">
      <Setter Property="Height" Value="40" />
      <Setter Property="Padding" Value="17,0" />
      <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="Background" Value="{DynamicResource SubtleButtonBrush}" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonSurface"
                    Background="{TemplateBinding Background}"
                    CornerRadius="9"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource SubtleButtonHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.72" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.38" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource QuietButtonStyle}">
      <Setter Property="Height" Value="44" />
      <Setter Property="MinWidth" Value="218" />
      <Setter Property="Padding" Value="22,0" />
      <Setter Property="Foreground" Value="White" />
      <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonSurface"
                    Background="{TemplateBinding Background}"
                    CornerRadius="10"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RecognizesAccessKey="True" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource AccentHoverBrush}" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonSurface" Property="Background" Value="{DynamicResource AccentPressedBrush}" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="ButtonSurface" Property="Opacity" Value="0.38" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource QuietButtonStyle}">
      <Setter Property="Width" Value="38" />
      <Setter Property="Height" Value="38" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="FontFamily" Value="Segoe Fluent Icons, Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="17" />
      <Setter Property="FontWeight" Value="Normal" />
      <Setter Property="ToolTipService.ShowDuration" Value="10000" />
    </Style>

    <Style x:Key="MetadataLabelStyle" TargetType="TextBlock">
      <Setter Property="Width" Value="98" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <Style x:Key="MetadataValueStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>
  </Window.Resources>

  <Border Background="{DynamicResource WindowBackgroundBrush}">
    <Grid Margin="34,26,34,24">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="20" />
        <RowDefinition Height="*" />
        <RowDefinition Height="22" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="17" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="15" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Border Width="52" Height="52" CornerRadius="12" ClipToBounds="True">
          <Image Source="Assets/TrainTimerIcon.png" Stretch="UniformToFill" />
        </Border>

        <StackPanel Grid.Column="2" VerticalAlignment="Center">
          <TextBlock Text="TrainTimer"
                     FontFamily="{StaticResource DisplayFont}"
                     FontSize="24"
                     FontWeight="SemiBold" />
          <TextBlock x:Name="SubtitleText"
                     Margin="0,3,0,0"
                     Text="本地计时器服务 · 服务就绪后自动在 Chrome 中打开"
                     FontSize="13"
                     Foreground="{DynamicResource TextSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Top">
          <Button x:Name="RefreshButton"
                  Margin="0,0,8,0"
                  Style="{StaticResource IconButtonStyle}"
                  Content="&#xE72C;"
                  ToolTip="刷新服务状态 (Ctrl+R)"
                  Click="RefreshButton_Click" />
          <Button x:Name="LogButton"
                  Style="{StaticResource IconButtonStyle}"
                  Content="&#xE8A5;"
                  ToolTip="打开启动日志"
                  Click="LogButton_Click" />
        </StackPanel>
      </Grid>

      <Border Grid.Row="2"
              Padding="26,24,26,22"
              Background="{DynamicResource CardBrush}"
              BorderBrush="{DynamicResource CardBorderBrush}"
              BorderThickness="1"
              CornerRadius="16">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="22" />
            <RowDefinition Height="1" />
            <RowDefinition Height="20" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="13" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="13" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="50" />
              <ColumnDefinition Width="18" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border x:Name="StatusCircle"
                    Width="44"
                    Height="44"
                    CornerRadius="22"
                    Background="{DynamicResource StatusAmberBrush}"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Center">
              <TextBlock x:Name="StatusGlyph"
                         Text="&#xE895;"
                         FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                         FontSize="21"
                         Foreground="White"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center" />
            </Border>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
              <TextBlock x:Name="StatusTitleText"
                         Text="正在准备 TrainTimer"
                         FontFamily="{StaticResource DisplayFont}"
                         FontSize="21"
                         FontWeight="SemiBold" />
              <TextBlock x:Name="StatusMessageText"
                         Margin="0,3,0,0"
                         Text="正在启动本地服务。"
                         FontSize="13"
                         Foreground="{DynamicResource TextSecondaryBrush}" />
            </StackPanel>
          </Grid>

          <Border Grid.Row="2" Background="{DynamicResource DividerBrush}" />

          <Grid Grid.Row="4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="30" />
              <ColumnDefinition Width="98" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE71B;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Style="{StaticResource MetadataLabelStyle}" Text="网页地址" />
            <TextBlock x:Name="AddressText" Grid.Column="2" Style="{StaticResource MetadataValueStyle}" FontFamily="Cascadia Mono, Consolas" Text="http://127.0.0.1:3211" />
            <Button x:Name="CopyButton" Grid.Column="3" Style="{StaticResource IconButtonStyle}" Width="34" Height="30" Content="&#xE8C8;" ToolTip="复制网页地址" Click="CopyButton_Click" />
          </Grid>

          <Grid Grid.Row="6">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="30" />
              <ColumnDefinition Width="98" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Style="{StaticResource MetadataLabelStyle}" Text="浏览器" />
            <TextBlock x:Name="BrowserText" Grid.Column="2" Style="{StaticResource MetadataValueStyle}" Text="Google Chrome · 启动后自动打开" />
          </Grid>

          <Grid Grid.Row="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="30" />
              <ColumnDefinition Width="98" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15" Foreground="{DynamicResource TextTertiaryBrush}" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1" Style="{StaticResource MetadataLabelStyle}" Text="访问范围" />
            <TextBlock Grid.Column="2" Style="{StaticResource MetadataValueStyle}" Text="仅这台 Windows 电脑可访问" />
          </Grid>
        </Grid>
      </Border>

      <Grid Grid.Row="4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="10" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="14" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <Button x:Name="StopButton" Grid.Column="1" Style="{StaticResource QuietButtonStyle}" Click="StopButton_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE71A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Text="停止服务" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button x:Name="RestartButton" Grid.Column="3" Style="{StaticResource QuietButtonStyle}" Click="RestartButton_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
            <TextBlock Text="重新启动" VerticalAlignment="Center" />
          </StackPanel>
        </Button>

        <Button x:Name="PrimaryButton" Grid.Column="5" Style="{StaticResource PrimaryButtonStyle}" Click="PrimaryButton_Click">
          <StackPanel Orientation="Horizontal">
            <TextBlock Text="&#xE774;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="16" Foreground="White" Margin="0,0,9,0" VerticalAlignment="Center" />
            <TextBlock x:Name="PrimaryButtonText" Text="在 Chrome 中打开" Foreground="White" VerticalAlignment="Center" />
          </StackPanel>
        </Button>
      </Grid>

      <Grid Grid.Row="6">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock x:Name="LastCheckedText"
                   Text="准备检查服务状态"
                   FontSize="12"
                   Foreground="{DynamicResource TextTertiaryBrush}"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
          <TextBlock Text="&#xE946;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13" Foreground="{DynamicResource TextTertiaryBrush}" Margin="0,0,7,0" />
          <TextBlock Text="关闭窗口即停止由本程序启动的服务" FontSize="12" Foreground="{DynamicResource TextTertiaryBrush}" />
        </StackPanel>
      </Grid>
    </Grid>
  </Border>
</Window>
